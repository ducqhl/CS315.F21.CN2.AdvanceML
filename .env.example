# .env.example
# Environment variable template for the Crypto Big Data project.
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# NEVER commit .env — it is listed in .gitignore.
# This file (.env.example) IS committed — it documents required variables
# but contains NO real secrets.

# ── CoinGecko ─────────────────────────────────────────────────────────────────
# CoinGecko demo API key (required for demo tier; get one at https://www.coingecko.com/en/api)
COINGECKO_API_KEY=your_demo_api_key_here

# Poll interval in seconds — demo tier: use 600 (10 min) to stay < 10k calls/month
POLL_INTERVAL_SECONDS=600

# Coins to track (comma-separated CoinGecko IDs)
COINGECKO_COIN_IDS=bitcoin,dogecoin

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Inside Docker network services use kafka:29092 (PLAINTEXT listener)
# Outside Docker (local development) use localhost:9092 (PLAINTEXT_HOST listener)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

KAFKA_TOPIC_RAW=crypto_raw
KAFKA_TOPIC_ALERTS=crypto_alerts
KAFKA_TOPIC_PREDICTIONS=crypto_predictions

# ── MongoDB ───────────────────────────────────────────────────────────────────
# CHANGE the username and password from defaults before production use.
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password123

MONGO_DB=crypto_db

# Full URI used by application services (authSource=admin required for mongo:7.0)
MONGO_URI=mongodb://admin:password123@localhost:27017/crypto_db?authSource=admin

# ── Spark ─────────────────────────────────────────────────────────────────────
# spark-master hostname as seen from within the Docker network
SPARK_MASTER=spark://spark-master:7077

# Checkpoint directory inside the container — persists state for streaming job
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoints

# ── Streamlit Dashboard ───────────────────────────────────────────────────────
# Auto-refresh interval for the real-time page (seconds)
DASHBOARD_REFRESH_SECONDS=30
