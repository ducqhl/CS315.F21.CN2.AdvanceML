# .gitignore — Crypto Big Data Project

# ── Secrets & local config ────────────────────────────────────────────────────
.env

# ── Large / sensitive datasets ────────────────────────────────────────────────
data/g-research/

# ── Trained model weights & scalers ──────────────────────────────────────────
*.pt
*.pth
*.pkl
src/ml/model/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc

# ── Python packaging ──────────────────────────────────────────────────────────
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter notebooks checkpoints ────────────────────────────────────────────
.ipynb_checkpoints/

# ── Spark ─────────────────────────────────────────────────────────────────────
spark-warehouse/
derby.log
metastore_db/

# ── Docker volumes / generated data ──────────────────────────────────────────
data/mongo_backup/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── pytest cache ──────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── mypy / type checking ──────────────────────────────────────────────────────
.mypy_cache/
node_modules

# ── LaTeX build artifacts (docs/report) ──────────────────────────────────────
docs/report/*.aux
docs/report/*.bbl
docs/report/*.blg
docs/report/*.fdb_latexmk
docs/report/*.fls
docs/report/*.lof
docs/report/*.log
docs/report/*.lot
docs/report/*.out
docs/report/*.pdf
docs/report/*.synctex.gz
docs/report/*.toc
docs/report/missfont.log
